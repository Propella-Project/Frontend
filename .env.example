# Propella App Environment Variables

# Public site URL (no trailing slash) — canonical URLs, OG tags, sitemap/robots should match
# VITE_SITE_URL=https://propella.ng

# Optional: absolute URL to Open Graph / Twitter preview image (1200×630 recommended)
# VITE_OG_IMAGE_URL=https://propella.ng/og-image.png

# Main Backend API (base URL for the backend; include /api if your API is under /api)
VITE_API_BASE_URL=https://propella-api.vercel.app/api
VITE_API_TIMEOUT=30000

# AI Engine API
VITE_AI_ENGINE_BASE_URL=https://ai-api.propella.ng
VITE_AI_ENGINE_API_KEY=propella_I39LKNbV1DUWbeOl4DgXZ-Ox0XrdGHdaRmjvqrsxE9M
# propella_Y6hk4YELQq24AYvafVfoC5kyqsF9d-K4Af64SwDxVIw
VITE_AI_ENGINE_TIMEOUT=60000

# Roadmap lesson notes: omit or any value = dummy HTML; set to false to use GET /api/notes/:topicId
# VITE_USE_DUMMY_NOTES=false

# Feature Flags (optional)
VITE_ENABLE_AI_ENGINE=true
VITE_ENABLE_AI_VOICE=true
VITE_ENABLE_PAYMENT=true

# Flutterwave (flutterwave-react-v3) - public key only, safe on client
VITE_FLUTTERWAVE_PUBLIC_KEY=


 